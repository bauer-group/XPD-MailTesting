# =============================================================================
# Mailpit stack — optional overrides
# =============================================================================
# Copy to .env and adjust. Everything works without this file — all defaults
# live in the image. This only exposes the few knobs worth touching.
#   cp .env.example .env
# =============================================================================

# --- Host ports (change only if 8025/1025/1110 collide with another stack) ---
MP_UI_PORT=8025
MP_SMTP_PORT=1025
MP_POP3_PORT=1110

# --- Encryption mode ---------------------------------------------------------
# Default (both unset): the SMTP port speaks plain text AND STARTTLS.
# To test implicit TLS (SMTPS, like classic port 465) set BOTH lines below:
#   MP_SMTP_REQUIRE_TLS=true           require TLS from the first byte (disables STARTTLS)
#   MP_SMTP_AUTH_ALLOW_INSECURE=false  required — "TLS always" conflicts with insecure auth
# Mailpit serves only ONE mode per instance.
MP_SMTP_REQUIRE_TLS=
MP_SMTP_AUTH_ALLOW_INSECURE=

# --- Web UI / API basic auth (empty = open) ----------------------------------
# Space-separated user:pass pairs, e.g. dev:dev
MP_UI_AUTH=

# --- POP3 (disabled until set) -----------------------------------------------
# Space-separated user:pass pairs, e.g. dev:dev
MP_POP3_AUTH=
